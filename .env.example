# Monarch Configuration
# ---------------------
# This file contains environment variables required for Monarch to function.
# Copy this file to .env and fill in your API keys and configuration.

# === LLM Provider API Keys ===

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_ORG_ID=your_organization_id_here_if_applicable

# Anthropic API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_API_BASE_URL=https://api.anthropic.com

# Google AI (Gemini) API Configuration
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_API_BASE_URL=https://generativelanguage.googleapis.com/v1

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_BASE_URL=https://api.groq.com/v1

# Cerebras API Configuration
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_API_BASE_URL=https://api.cerebras.com/v1

# Ollama Configuration (for local models)
OLLAMA_API_BASE_URL=http://localhost:11434/api

# Custom OpenAI-Compatible Provider
CUSTOM_OPENAI_API_KEY=your_custom_provider_api_key_here
CUSTOM_OPENAI_API_BASE_URL=your_custom_provider_base_url_here

# === Google Workspace Integration ===

# OAuth 2.0 Client Configuration
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
GOOGLE_REDIRECT_URI=chrome-extension://extension_id/oauth_callback.html

# Google Workspace Scopes (comma-separated)
# Example: https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/drive.readonly
GOOGLE_WORKSPACE_SCOPES=your_required_scopes_here

# === Extension Configuration ===

# Default Agent Mode (agent, research)
DEFAULT_AGENT_MODE=agent

# Default Models for Different Agents
DEFAULT_PLANNER_MODEL=claude-3-5-sonnet
DEFAULT_NAVIGATOR_MODEL=claude-3-5-haiku
DEFAULT_VALIDATOR_MODEL=claude-3-5-haiku

# Debug Mode (true/false)
DEBUG_MODE=false
