# Monarch AI Browser Assistant - Configuration
# --------------------------------------------------
# Copy this file to .env in the root directory of the project and fill in your details.
# This file is for local development and for users who wish to use their own API keys.
# For commercial distribution, the distributor (Monarch team) would pre-configure
# the MONARCH_PROVIDED_ keys or manage them via a backend service.

# === API Key Configuration ===
# Set USE_MONARCH_PROVIDED_KEYS to 'true' if you want the extension to use the API keys
# provided in the "Monarch Provided API Keys" section below (typically pre-filled by the Monarch distributor).
# Set to 'false' if you want to use your own API keys from the "User Provided API Keys" section.
USE_MONARCH_PROVIDED_KEYS=false

# --- Monarch Provided API Keys (For Distributor Use) ---
# If USE_MONARCH_PROVIDED_KEYS is 'true', the extension will attempt to use these keys.
# These would be set by the Monarch team for a distributed version.
MONARCH_OPENAI_API_KEY=your_monarch_distributor_openai_api_key_here
MONARCH_ANTHROPIC_API_KEY=your_monarch_distributor_anthropic_api_key_here
MONARCH_GOOGLE_API_KEY=your_monarch_distributor_google_api_key_here
# Add other MONARCH_PROVIDED_ keys for other services if needed.

# --- User Provided API Keys (For Individual User/Developer Use) ---
# If USE_MONARCH_PROVIDED_KEYS is 'false', the extension will attempt to use these keys.
# Please fill these in with your personal/development API keys.

# OpenAI API Configuration
USER_OPENAI_API_KEY=your_personal_openai_api_key_here
# Optional: Organization ID for OpenAI
# USER_OPENAI_ORG_ID=your_organization_id_here_if_applicable

# Anthropic API Configuration
USER_ANTHROPIC_API_KEY=your_personal_anthropic_api_key_here

# Google AI (Gemini) API Configuration
USER_GOOGLE_API_KEY=your_personal_google_api_key_here

# Ollama Configuration (for running local models)
# If you are using Ollama, specify its base URL. Default is usually http://localhost:11434.
# No API key is typically needed for local Ollama.
OLLAMA_API_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY= (Usually not required)

# Custom OpenAI-Compatible Provider (for other LLMs with an OpenAI-like API)
# Useful for services like Together AI, Anyscale, or self-hosted models.
CUSTOM_PROVIDER_NAME=MyCustomLLM # A user-friendly name for this custom provider
CUSTOM_PROVIDER_API_KEY=your_custom_provider_api_key_here
CUSTOM_PROVIDER_API_BASE_URL=your_custom_provider_base_url_here # e.g., https://api.together.xyz/v1

# === Google Workspace Integration (OAuth 2.0) ===
# These are required if you want Monarch to interact with your Google Workspace data
# (Gmail, Drive, Calendar, etc.). You'll need to set up an OAuth 2.0 client ID
# in the Google Cloud Console.

# 1. Google OAuth Client ID:
#    Your application's client ID obtained from Google Cloud Console.
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here.apps.googleusercontent.com

# 2. Google OAuth Client Secret:
#    Your application's client secret obtained from Google Cloud Console.
#    IMPORTANT: Keep this secret confidential. For a packaged extension, this
#    secret might need to be handled by a backend proxy for security.
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here

# 3. Google OAuth Redirect URI:
#    This URI must be registered in your Google Cloud Console OAuth client settings.
#    For Chrome extensions, it typically looks like: chrome-extension://YOUR_EXTENSION_ID_HERE/oauth_callback.html
#    To find YOUR_EXTENSION_ID_HERE:
#      a. Load Monarch into Chrome (e.g., via chrome://extensions -> Load unpacked).
#      b. The ID will be visible on the extension's card.
#    Example: chrome-extension://abcdefghijklmnopqrstuvwxyzabcdef/oauth_callback.html
GOOGLE_REDIRECT_URI=chrome-extension://YOUR_EXTENSION_ID_HERE/oauth_callback.html

# 4. Google Workspace Scopes:
#    A comma-separated list of permissions Monarch will request from the user.
#    Only request scopes that are absolutely necessary for the features you intend to use.
#    Requesting too many scopes can deter users.
#
#    Common Scopes:
#    - Gmail (Read-only): https://www.googleapis.com/auth/gmail.readonly
#    - Google Drive (Read-only): https://www.googleapis.com/auth/drive.readonly
#    - Google Drive (Full access): https://www.googleapis.com/auth/drive
#    - Google Calendar (Read-only): https://www.googleapis.com/auth/calendar.readonly
#    - Google Contacts (Read-only): https://www.googleapis.com/auth/contacts.readonly
#    - Basic profile info: https://www.googleapis.com/auth/userinfo.email,https://www.googleapis.com/auth/userinfo.profile
#
#    Find a full list of available scopes at: https://developers.google.com/identity/protocols/oauth2/scopes
#
#    Example for reading emails and drive files:
GOOGLE_WORKSPACE_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/drive.readonly,https://www.googleapis.com/auth/userinfo.email,https://www.googleapis.com/auth/userinfo.profile

# === Extension Behavior ===

# Debug Mode (true/false)
# Set to 'true' to enable more verbose logging and developer features.
# Should be 'false' for production/distribution.
DEBUG_MODE=false
